   "source": [
    "num = int(input(\"Enter the number\"))\n",
    "\n",
    "if num<=1:\n",
    "    print(\"Not a prime number\")\n",
    "else:\n",
    "    for i in range (2, (num**0.5)+1):\n",
    "        if num%i == 0:\n",
    "            print(\"Not a prime number\")\n",
    "            break\n",
    "        else:\n",
    "            print(\"Prime number\")"
   ]
